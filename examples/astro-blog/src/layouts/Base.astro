---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · ledric sample</title>
    <style is:global>
      :root {
        --bg: #0e0f12;
        --panel: #15171c;
        --ink: #e8e6df;
        --muted: #8a8b8e;
        --accent: #f7b955;
        --line: #24262d;
        --max: 1080px;
      }

      * { box-sizing: border-box; }
      html, body {
        margin: 0; padding: 0;
        background: var(--bg);
        color: var(--ink);
        font: 16px/1.55 ui-sans-serif, -apple-system, "Inter", "Helvetica Neue", sans-serif;
      }

      a {
        color: inherit;
      }
      a:hover { color: var(--accent); }

      nav.topbar {
        max-width: var(--max);
        margin: 0 auto;
        padding: 24px 24px 16px;
        display: flex;
        gap: 18px;
        align-items: baseline;
        border-bottom: 1px solid var(--line);
        font-size: 14px;
        letter-spacing: 0.04em;
      }
      nav.topbar .brand {
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        margin-right: auto;
        color: var(--muted);
      }
      nav.topbar a { text-decoration: none; color: var(--muted); }
      nav.topbar a.active, nav.topbar a:hover { color: var(--ink); }

      header.page {
        max-width: var(--max);
        margin: 0 auto;
        padding: 56px 24px 28px;
      }
      header.page h1 {
        margin: 0;
        font-size: 44px;
        font-weight: 600;
        letter-spacing: -0.02em;
      }
      header.page p {
        margin: 12px 0 0;
        color: var(--muted);
        font-size: 18px;
      }

      main {
        max-width: var(--max);
        margin: 0 auto;
        padding: 24px 24px 80px;
      }

      footer.page {
        max-width: var(--max);
        margin: 0 auto;
        padding: 24px;
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: 13px;
      }
      footer.page code {
        background: var(--panel);
        padding: 2px 6px;
        border-radius: 4px;
      }

      .meta-row {
        color: var(--muted);
        font-size: 13px;
      }

      .tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 8px;
      }
      .tags span {
        font-size: 11px;
        color: var(--muted);
        border: 1px solid var(--line);
        padding: 3px 8px;
        border-radius: 999px;
      }

      .hero, .hero-placeholder {
        width: 100%;
        aspect-ratio: 16 / 9;
        background: var(--panel);
        border-radius: 6px;
        object-fit: cover;
        display: block;
      }
      .hero-placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: 12px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }
    </style>
  </head>
  <body>
    <nav class="topbar">
      <span class="brand">ledric · sample</span>
      <a href="/" class={Astro.url.pathname === '/' || Astro.url.pathname.startsWith('/posts') ? 'active' : ''}>blog</a>
      <a href="/products" class={Astro.url.pathname.startsWith('/products') ? 'active' : ''}>products</a>
    </nav>

    {(title || subtitle) && (
      <header class="page">
        <h1>{title}</h1>
        {subtitle && <p>{subtitle}</p>}
      </header>
    )}

    <main>
      <slot />
    </main>

    <footer class="page">
      Rendered server-side from <code>@ledric/sdk</code>. Hero bytes streamed from the same SQLite file via <code>GET /assets/&lt;id&gt;</code>.
    </footer>
  </body>
</html>
