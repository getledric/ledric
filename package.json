{
  "name": "@ledric/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "ledric monorepo root — MCP/LLM-native self-hosted CMS.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getledric/ledric.git"
  },
  "bugs": "https://github.com/getledric/ledric/issues",
  "homepage": "https://github.com/getledric/ledric#readme",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --filter '!@ledric/example-*' run build",
    "dev": "pnpm -r --parallel --filter '!@ledric/example-*' run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cli": "pnpm build && vitest run e2e-cli/",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "clean": "pnpm -r --filter '!@ledric/example-*' run clean",
    "cli": "node packages/cli/dist/cli.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.9.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "^3.1.2",
      "ip-address": "^10.1.1",
      "hono": "^4.12.18",
      "esbuild": "^0.25.0",
      "vite": "^6.4.2"
    }
  }
}
