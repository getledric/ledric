{
  "name": "ledric",
  "version": "0.3.1",
  "description": "ledric CLI — single-binary entry point.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getledric/ledric.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/getledric/ledric/issues",
  "homepage": "https://github.com/getledric/ledric#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": "./dist/cli.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepack": "tsup"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@ledric/core": "workspace:*",
    "@ledric/gui": "workspace:*",
    "@ledric/http-server": "workspace:*",
    "@ledric/mcp-server": "workspace:*",
    "@ledric/oauth": "workspace:*",
    "@ledric/schema": "workspace:*",
    "@ledric/storage": "workspace:*",
    "citty": "^0.1.6"
  }
}
