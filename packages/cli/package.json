{
  "name": "ledric",
  "version": "0.0.0",
  "description": "ledric CLI — single-binary entry point.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": "./dist/cli.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ledric/core": "workspace:*",
    "@ledric/http-server": "workspace:*",
    "@ledric/mcp-server": "workspace:*",
    "@ledric/storage": "workspace:*",
    "citty": "^0.1.6"
  }
}
