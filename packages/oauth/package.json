{
  "name": "@ledric/oauth",
  "version": "0.3.7",
  "description": "OAuth 2.1 provider for ledric — DCR + auth code + PKCE + JWT/JWKS, single-process, no external IdP. Mounted by @ledric/http-server when mcp.public is on.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getledric/ledric.git",
    "directory": "packages/oauth"
  },
  "bugs": "https://github.com/getledric/ledric/issues",
  "homepage": "https://github.com/getledric/ledric#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepack": "tsup"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ledric/storage": "workspace:*",
    "jose": "^5.9.6",
    "oidc-provider": "^9.8.3"
  },
  "devDependencies": {
    "@types/oidc-provider": "^9.5.0"
  }
}
