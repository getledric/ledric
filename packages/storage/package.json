{
  "name": "@ledric/storage",
  "version": "0.1.2",
  "description": "ledric storage: Kysely-based dialect adapters. SQLite (better-sqlite3) default; MySQL and Postgres also supported.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getledric/ledric.git",
    "directory": "packages/storage"
  },
  "bugs": "https://github.com/getledric/ledric/issues",
  "homepage": "https://github.com/getledric/ledric#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepack": "tsup"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ledric/schema": "workspace:*",
    "better-sqlite3": "^11.5.0",
    "kysely": "^0.27.4",
    "uuid": "^11.0.3"
  },
  "peerDependencies": {
    "mysql2": "^3.11.0",
    "pg": "^8.13.0"
  },
  "peerDependenciesMeta": {
    "mysql2": { "optional": true },
    "pg": { "optional": true }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/pg": "^8.11.10",
    "mysql2": "^3.11.0",
    "pg": "^8.13.0"
  }
}
