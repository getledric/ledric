{
  "name": "@ledric/storage",
  "version": "0.0.0",
  "description": "ledric storage: Drizzle-based adapter(s). SQLite (better-sqlite3) default, Postgres as second target.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ledric/schema": "workspace:*",
    "better-sqlite3": "^11.5.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12"
  }
}
