{
  "name": "@ledric/gui",
  "version": "0.4.0",
  "description": "ledric admin GUI — React via CDN, served by @ledric/http-server.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getledric/ledric.git",
    "directory": "packages/gui"
  },
  "bugs": "https://github.com/getledric/ledric/issues",
  "homepage": "https://github.com/getledric/ledric#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web/*": "./web/*"
  },
  "files": [
    "dist",
    "web"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepack": "tsup"
  },
  "publishConfig": {
    "access": "public"
  }
}
