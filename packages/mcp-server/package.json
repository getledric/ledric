{
  "name": "@ledric/mcp-server",
  "version": "0.4.0",
  "description": "ledric MCP server: MCP tool surface bound to @ledric/core (stdio + HTTP+SSE).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getledric/ledric.git",
    "directory": "packages/mcp-server"
  },
  "bugs": "https://github.com/getledric/ledric/issues",
  "homepage": "https://github.com/getledric/ledric#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepack": "tsup"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ledric/core": "workspace:*",
    "@ledric/schema": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ledric/storage": "workspace:*"
  }
}
